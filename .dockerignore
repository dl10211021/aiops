# 忽略不需要打包到镜像里的文件和目录，减小镜像体积
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境
venv/
env/
ENV/
.env

# 打包构建产物
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 历史记录/临时文件
.git/
.gitignore
.idea/
.vscode/
temp_sandbox/
*.log
tmp_history.json
.git_log_frontend.txt

# 本地数据库 (不要打包进初始镜像，因为我们希望通过挂载或启动后生成)
opscore.db
opscore.db-shm
opscore.db-wal
cron_jobs.sqlite
opscore_lancedb/

# 其他无关文件
OpsCore.spec
README.md
