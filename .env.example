# OpsCore production environment template.
# Copy to .env on the deployment host and replace placeholder values.

# Server
OPSCORE_HOST=0.0.0.0
OPSCORE_PORT=8000
LOG_LEVEL=INFO
OPSCORE_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# API security
# Set a long random value. Frontend requests must include X-API-Key with this token.
OPSCORE_API_TOKEN=change-me-use-a-long-random-token

# LLM provider defaults
OPENAI_BASE_URL=http://127.0.0.1:8001/v1
OPENAI_API_KEY=change-me
OPENAI_MODEL=qwen3.6-35b-a3b-awq

# Embeddings / knowledge base
EMBEDDING_MODEL=
EMBEDDING_DIM=3072
OPSCORE_DISABLE_LTM=0

# Runtime safety
OPSCORE_ENV=production
OPSCORE_LOG_DIR=logs
OPSCORE_BACKUP_DIR=backups

# Oracle legacy compatibility
# Set thick mode when old Oracle users only have 10G password verifiers.
# Requires Oracle Instant Client installed on the machine running OpsCore.
OPSCORE_ORACLE_THICK_MODE=false
OPSCORE_ORACLE_CLIENT_LIB_DIR=
